# Cookie Worker local config
# Copy to tools/cookie-worker/.env and fill in the values.

# VPS or local main API base.
API_BASE=http://127.0.0.1:8787

# Must match COOKIE_SYNC_TOKEN in the main service.
COOKIE_SYNC_TOKEN=

# Accounts to sync, comma separated.
GEMINI_ACCOUNTS=acc1,acc2,acc3

# Single-account override when you only want one account.
# COOKIE_WORKER_ACCOUNT=acc1

# Browser mode.
COOKIE_WORKER_HEADLESS=true
COOKIE_WORKER_OPEN_ONLY=false
COOKIE_WORKER_ONCE=true
COOKIE_WORKER_MIN_INTERVAL_MINUTES=90
COOKIE_WORKER_MAX_INTERVAL_MINUTES=180
COOKIE_WORKER_POST_RETRIES=3
COOKIE_WORKER_POST_RETRY_DELAY_MS=2000
COOKIE_WORKER_BROWSER_CHANNEL=chrome

# Per-account profile directories and proxies.
GEMINI_ACCOUNT_ACC1_PROFILE_DIR=profiles/acc1
GEMINI_ACCOUNT_ACC1_PROXY=http://127.0.0.1:10808
GEMINI_ACCOUNT_ACC2_PROFILE_DIR=profiles/acc2
GEMINI_ACCOUNT_ACC2_PROXY=http://127.0.0.1:8019/
GEMINI_ACCOUNT_ACC3_PROFILE_DIR=profiles/acc3
GEMINI_ACCOUNT_ACC3_PROXY=http://127.0.0.1:8017/
