# Server Configuration
PORT=8787
LOG_LEVEL=info
APP_ENV=development
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Gemini Configuration
# To get these values, visit https://gemini.google.com and log in
# Then open Developer Tools (F12) -> Application/Storage tab -> Cookies -> https://google.com
GEMINI_1PSID=
GEMINI_1PSIDTS=
GEMINI_REFRESH_INTERVAL=2
GEMINI_MAX_RETRIES=3

# Stream debugging. Enable temporarily while diagnosing Pro/thinking output.
# OPENAI_DEBUG_REQUEST_LOG=false
# GEMINI_TRACE_STREAM=true
# GEMINI_DEBUG_STREAM_DIR=scratch/upstream_debug
# GEMINI_DEBUG_REQUEST_PATH=scratch/latest.request.json
# GEMINI_DEBUG_STREAM_PATH=scratch/latest.raw.txt
# GEMINI_DEBUG_ENTRY_TRACE_PATH=scratch/latest.entry_trace.json
# GEMINI_STREAM_FINISH_IDLE_MS=15000
# GEMINI_WEB_STREAM_QUERY=false
