# =============================================================================
# Gemini Web to API - recommended daily configuration
# Gemini Web to API - 推荐日常配置
# =============================================================================
# Copy this file to .env, then fill only the secrets/profile/proxy values you use.
# 复制为 .env 后，只填写你实际使用的密钥、profile 和代理。
#
# Do not commit .env, data/cookies/accounts.json, or browser profile folders.
# 不要提交 .env、data/cookies/accounts.json 或浏览器 profile 目录。

# -----------------------------------------------------------------------------
# Server / 服务
# -----------------------------------------------------------------------------
PORT=8787
LOG_LEVEL=info
APP_ENV=development

# Local rate limit for API requests.
# 本地 API 请求限流。
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

# Required for /admin/* cookie sync APIs and the Playwright cookie worker.
# /admin/* Cookie 同步接口和 Playwright Cookie Worker 都需要这个 token。
#
# Use a long random value in real deployment.
# 正式部署时请使用足够长的随机值。
COOKIE_SYNC_TOKEN=

# -----------------------------------------------------------------------------
# Proxy / 代理
# -----------------------------------------------------------------------------
# Legacy/default proxy. In single-account mode this is used by Gemini requests.
# 旧版/默认代理。单账号模式下 Gemini 请求会使用它。
#
# In multi-account mode, each GEMINI_ACCOUNT_<ID>_PROXY below is preferred.
# 多账号模式下，优先使用每个账号自己的 GEMINI_ACCOUNT_<ID>_PROXY。
#
# PROXY_URL does not override per-account proxies.
# PROXY_URL 不会覆盖账号级代理。
#
# Supported formats: http://host:port, socks5h://host:port
# 支持格式：http://host:port、socks5h://host:port
PROXY_URL=

# -----------------------------------------------------------------------------
# Gemini cookie and refresh behavior / Gemini Cookie 与刷新行为
# -----------------------------------------------------------------------------
# Legacy single-account cookies. Leave empty when using GEMINI_ACCOUNTS below.
# 旧版单账号 Cookie。使用下面的 GEMINI_ACCOUNTS 多账号模式时可留空。
GEMINI_1PSID=
GEMINI_1PSIDTS=

# Scheduled RotateCookies interval in minutes. 1440 keeps background churn low.
# 定时 RotateCookies 间隔，单位分钟。1440 可以减少后台刷新频率。
#
# Worker/profile sync is used when cookies are fully invalid.
# Cookie 完全失效时由 Worker/profile 同步兜底。
GEMINI_REFRESH_INTERVAL=1440
GEMINI_MAX_RETRIES=3

# Worker-synced cookies are persisted here and override stale .env cookie values.
# Worker 同步成功的 Cookie 会持久化到这里，并覆盖 .env 里的旧 Cookie。
GEMINI_COOKIE_CACHE_ENABLED=true
GEMINI_COOKIE_CACHE_PATH=data/cookies/accounts.json

# Active account rotation state. Keeping this file means restart does not reset
# the current account's remaining stay window.
# Active 账号轮换状态。保留此文件后，重启不会重置当前账号剩余停留时间。
GEMINI_ACCOUNT_STATE_PATH=data/state/accounts.json

# Lightweight account audit logs: account selection, conversation binding,
# cookie sync, and refresh events. Does not log cookie values.
# 轻量账号审计日志：账号选择、会话绑定、Cookie 同步和刷新事件；不会记录 Cookie 值。
GEMINI_ACCOUNT_AUDIT_LOG=true

# -----------------------------------------------------------------------------
# Multi-account mode / 多账号模式
# -----------------------------------------------------------------------------
# Recommended mode. Cookies may be empty here if the cookie worker has already
# synced them to GEMINI_COOKIE_CACHE_PATH.
# 推荐模式。如果 Cookie Worker 已同步到 GEMINI_COOKIE_CACHE_PATH，这里可不填 Cookie。
#
# Priority controls both order and stay multiplier:
#   actual stay = GEMINI_ACCOUNT_<ID>_STAY_MINUTES * max(priority, 1)
# 优先级同时控制选择顺序和停留时间倍率：
#   实际停留时间 = GEMINI_ACCOUNT_<ID>_STAY_MINUTES * max(priority, 1)
#
# Existing conversations stay bound to their first account; rotation only affects
# new conversations.
# 已有对话会固定绑定首次使用的账号；轮换只影响新对话。
#
# Example / 示例：
#   acc1 priority 3 and stay 60 => 180 minutes
#   acc1 priority 3，stay 60 => 180 分钟
#   acc2 priority 1 and stay 60 => 60 minutes
#   acc2 priority 1，stay 60 => 60 分钟
GEMINI_ACCOUNTS=

# Account 1: preferred account.
# 账号 1：优先账号。
GEMINI_ACCOUNT_ACC1_1PSID=
GEMINI_ACCOUNT_ACC1_1PSIDTS=
GEMINI_ACCOUNT_ACC1_PROXY=http://127.0.0.1:10808
GEMINI_ACCOUNT_ACC1_PRIORITY=3
GEMINI_ACCOUNT_ACC1_STAY_MINUTES=60
GEMINI_ACCOUNT_ACC1_PROFILE_DIR=profiles/acc1

# Account 2: backup account. Leave cookies empty if worker cache is used.
# 账号 2：备用账号。使用 Worker 缓存时 Cookie 可留空。
GEMINI_ACCOUNT_ACC2_1PSID=
GEMINI_ACCOUNT_ACC2_1PSIDTS=
GEMINI_ACCOUNT_ACC2_PROXY=
GEMINI_ACCOUNT_ACC2_PRIORITY=1
GEMINI_ACCOUNT_ACC2_STAY_MINUTES=60
GEMINI_ACCOUNT_ACC2_PROFILE_DIR=profiles/acc2

# Account 3: backup account. Leave cookies empty if worker cache is used.
# 账号 3：备用账号。使用 Worker 缓存时 Cookie 可留空。
GEMINI_ACCOUNT_ACC3_1PSID=
GEMINI_ACCOUNT_ACC3_1PSIDTS=
GEMINI_ACCOUNT_ACC3_PROXY=
GEMINI_ACCOUNT_ACC3_PRIORITY=1
GEMINI_ACCOUNT_ACC3_STAY_MINUTES=60
GEMINI_ACCOUNT_ACC3_PROFILE_DIR=profiles/acc3

# -----------------------------------------------------------------------------
# Playwright cookie worker / Playwright Cookie Worker
# -----------------------------------------------------------------------------
# Main service can trigger this external worker when every account is unhealthy.
# 当所有账号都不可用时，主服务可自动触发这个外部 Worker。
#
# It runs in GEMINI_COOKIE_WORKER_DIR and calls /admin/accounts/<id>/cookies.
# 它会在 GEMINI_COOKIE_WORKER_DIR 中运行，并调用 /admin/accounts/<id>/cookies。
GEMINI_COOKIE_WORKER_ENABLED=true
GEMINI_COOKIE_WORKER_COMMAND=npm run sync --silent
GEMINI_COOKIE_WORKER_DIR=tools/cookie-worker
GEMINI_COOKIE_WORKER_TIMEOUT_SECONDS=120

# Worker defaults. Use headless=true after all accounts have logged-in profiles.
# Worker 默认值。所有账号 profile 都登录完成后，建议使用 headless=true。
API_BASE=http://127.0.0.1:8787
COOKIE_WORKER_HEADLESS=true
COOKIE_WORKER_OPEN_ONLY=false
COOKIE_WORKER_ONCE=false
COOKIE_WORKER_MIN_INTERVAL_MINUTES=90
COOKIE_WORKER_MAX_INTERVAL_MINUTES=180

# Retry only the POST upload to the main service after cookies were read from
# the browser profile. This avoids reopening the browser repeatedly when the
# VPS/admin endpoint is temporarily unreachable.
# 读取浏览器 profile 中的 Cookie 成功后，只重试上传到主服务这一步。
# 当 VPS/admin 接口临时不可达时，不会反复重新打开浏览器。
COOKIE_WORKER_POST_RETRIES=5
COOKIE_WORKER_POST_RETRY_DELAY_MS=3000

# Set this only when manually logging in or syncing one account from a shell.
# 只有手动登录或从命令行同步单个账号时才设置这个。
# COOKIE_WORKER_ACCOUNT=acc1

# -----------------------------------------------------------------------------
# OpenAI-compatible streaming / OpenAI 兼容流式输出
# -----------------------------------------------------------------------------
# Best daily path: no tools field, OpenAI-compatible streaming, source-path off.
# 日常最流畅路径：不传 tools 字段，使用 OpenAI 兼容流式，关闭 source-path。

# Short idle close keeps clients from waiting after visible output is complete.
# 短 idle 收尾可以避免客户端在可见输出完成后继续等待。
#
# Increase if long/thinking answers are cut off; set 0 to disable active close.
# 如果长回答或思考模型被截断，可以调大；设为 0 可关闭主动收尾。
GEMINI_STREAM_FINISH_IDLE_MS=1000

# Keep false by default. source-path caused Gemini 1097 on some server-side
# context continuations; enable only for A/B diagnosis.
# 默认保持 false。source-path 在部分服务端上下文续聊中会触发 Gemini 1097；
# 只建议在 A/B 排查时启用。
GEMINI_USE_SOURCE_PATH=false

# Tool calling is prompt-bridge based, not native Gemini Web tool calling.
# Leave disabled at the client side unless tools are really needed.
# 工具调用是 prompt 桥接，不是 Gemini Web 原生工具调用。
# 客户端除非确实需要工具，否则建议不要传 tools 字段。

# -----------------------------------------------------------------------------
# Debugging only - keep disabled for smooth daily use
# 仅调试使用 - 日常使用保持关闭以保证流畅
# -----------------------------------------------------------------------------
OPENAI_DEBUG_REQUEST_LOG=false
GEMINI_TRACE_STREAM=false
GEMINI_DEBUG_STREAM_DIR=
GEMINI_DEBUG_REQUEST_PATH=
GEMINI_DEBUG_STREAM_PATH=
GEMINI_DEBUG_ENTRY_TRACE_PATH=
GEMINI_WEB_STREAM_QUERY=false
